h3
    i.fas.fa-robot.me-2
    | Pilot Settings

.form-line
    .header
        .title API Configuration
        .description Configure your Anthropic API settings

.form-line
    .header
        .title API Key
        .description Your Anthropic API key (required)
    input.form-control(
        type='password',
        [(ngModel)]='config.store.pilot.apiKey',
        (ngModelChange)='saveConfig()',
        placeholder='sk-ant-...'
    )

.form-line
    .header
        .title Base URL
        .description Optional custom API endpoint
    input.form-control(
        type='text',
        [(ngModel)]='config.store.pilot.baseURL',
        (ngModelChange)='saveConfig()',
        placeholder='https://api.anthropic.com'
    )

.form-line
    .header
        .title Model
        .description Select the Claude model to use
    select.form-control(
        [(ngModel)]='config.store.pilot.model',
        (ngModelChange)='saveConfig()'
    )
        option(value='', disabled, selected) Select a model
        option(*ngFor='let model of modelOptions', [value]='model.value') {{model.label}}

.form-line
    .header
        .title Temperature
        .description Controls randomness (0.0 - 1.0)
    input.form-control(
        type='number',
        min='0',
        max='1',
        step='0.1',
        [(ngModel)]='config.store.pilot.temperature',
        (ngModelChange)='saveConfig()'
    )

.form-line
    .header
        .title Max Tokens
        .description Maximum tokens in response
    input.form-control(
        type='number',
        min='256',
        max='8192',
        step='256',
        [(ngModel)]='config.store.pilot.maxTokens',
        (ngModelChange)='saveConfig()'
    )

.alert.alert-info.mt-3
    i.fas.fa-info-circle.me-2
    | Get your API key from 
    a(href='https://console.anthropic.com/', target='_blank') console.anthropic.com
