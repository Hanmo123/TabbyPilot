{
  "name": "@tabby-pilot/plugin",
  "version": "0.1.0",
  "description": "AI Agent for Tabby - Copilot-style chat assistant",
  "keywords": [
    "tabby-plugin",
    "tabby",
    "ai",
    "assistant",
    "terminal",
    "copilot"
  ],
  "main": "dist/index.js",
  "typings": "typings/index.d.ts",
  "scripts": {
    "build:ai": "bun run --cwd ../ai-runtime build",
    "build": "bun run build:ai && webpack --progress --color",
    "watch": "bun run build:ai && webpack --progress --color --watch",
    "prepublishOnly": "bun run build"
  },
  "files": [
    "dist",
    "typings"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Hanmo123/tabby-pilot.git"
  },
  "homepage": "https://github.com/Hanmo123/tabby-pilot#readme",
  "bugs": {
    "url": "https://github.com/Hanmo123/tabby-pilot/issues"
  },
  "author": "Hanmo123",
  "license": "MIT",
  "devDependencies": {
    "@ngtools/webpack": "^15.2.4",
    "@tabby-pilot/ai-runtime": "workspace:*",
    "@types/node": "20.3.1",
    "apply-loader": "^2.0.0",
    "babel-loader": "^9.1.2",
    "css-loader": "^6.7.3",
    "pug": "^2.0.4",
    "pug-loader": "^2.4.0",
    "sass": "^1.58.3",
    "sass-loader": "^13.2.0",
    "source-map-loader": "^4.0.1",
    "style-loader": "^3.3.1",
    "tabby-core": "1.0.231-nightly.0",
    "tabby-settings": "1.0.231-nightly.0",
    "tabby-terminal": "1.0.231-nightly.0",
    "to-string-loader": "^1.2.0",
    "typescript": "~4.9.5",
    "webpack": "^5.76.2",
    "webpack-cli": "^5.0.1"
  },
  "dependencies": {
    "marked": "^18.0.5"
  },
  "peerDependencies": {
    "@angular/animations": "^15",
    "@angular/common": "^15",
    "@angular/compiler": "^15",
    "@angular/core": "^15",
    "@angular/forms": "^15",
    "@angular/platform-browser": "^15",
    "@ng-bootstrap/ng-bootstrap": "^14",
    "rxjs": "^7",
    "tabby-core": "*",
    "tabby-settings": "*",
    "tabby-terminal": "*"
  }
}
